generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id       String  @id @default(uuid())
  login    String  @unique
  password String
  info     Json?
  tasks    Task[]
}

model Task {
  id     String   @id @default(uuid())
  userId String
  date   DateTime
  tasks  Json
  user   User     @relation(fields: [userId], references: [id])
}