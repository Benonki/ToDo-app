generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String  @id @default(uuid())
  firebaseUid String  @unique
  email       String  @unique
  displayName String?
  info        Json?
  tasks       Task[]
}

model Task {
  id     String   @id @default(uuid())
  userId String
  date   DateTime
  tasks  Json

  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}